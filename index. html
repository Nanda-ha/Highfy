<a 
  href="#contact" 
  className="hidden md:block bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-slate-900 px-6 py-3 rounded-full font-semibold transition-all duration-300 shadow-gold hover:shadow-gold/50 transform hover:scale-105"
>
  Join Now
