</div>

{/* Mobile Menu */}
{isOpen && (
  <div className="md:hidden bg-slate-900/95 backdrop-blur-xl rounded-2xl mt-4 p-4">
    {navLinks.map((link) => (
      <a
        key={link.id}
        href={`#${link.id}`}
        onClick={() => setIsOpen(false)}
